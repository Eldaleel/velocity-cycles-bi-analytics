  <MdxScripts>
    <MdxScript dwd:design-time-name="8933e35f-1ce0-4af7-b0f3-6b0d6561b3e5">
      <ID>MdxScript</ID>
      <Name>MdxScript</Name>
      <CreatedTimestamp>0001-01-01T00:00:00Z</CreatedTimestamp>
      <LastSchemaUpdate>0001-01-01T00:00:00Z</LastSchemaUpdate>
      <Commands>
        <Command>
          <Text>/*
The CALCULATE command controls the aggregation of leaf cells in the cube.
If the CALCULATE command is deleted or modified, the data within the cube is affected.
You should edit this command only if you manually specify how the cube is aggregated.
*/
CALCULATE;
CREATE MEMBER CURRENTCUBE.[Measures].[Profit]
 AS [Measures].[Sales Amount] - [Measures].[Total Product Cost],
FORMAT_STRING = "Currency",
VISIBLE = 1;
CREATE MEMBER CURRENTCUBE.[Measures].[Top Gender Sales] AS
(
    HEAD(
        ORDER(
            NONEMPTY([Dim Customer].[Gender].Members, [Measures].[Sales Amount]),
            [Measures].[Sales Amount],
            DESC
        ),
        1
    ).Item(0),
    [Measures].[Sales Amount]
);
CREATE MEMBER CURRENTCUBE.[Measures].[Customer Age Group] AS
IIF(
    IsEmpty([Dim Customer].[Birth Date].CurrentMember.MEMBER_VALUE),
    "Unknown",
    IIF(
        DateDiff("yyyy", CDate([Dim Customer].[Birth Date].CurrentMember.MEMBER_VALUE), Now()) &lt; 18,
        "Under 18",
        IIF(
            DateDiff("yyyy", CDate([Dim Customer].[Birth Date].CurrentMember.MEMBER_VALUE), Now()) &lt;= 30,
            "18-30",
            IIF(
                DateDiff("yyyy", CDate([Dim Customer].[Birth Date].CurrentMember.MEMBER_VALUE), Now()) &lt;= 45,
                "31-45",
                IIF(
                    DateDiff("yyyy", CDate([Dim Customer].[Birth Date].CurrentMember.MEMBER_VALUE), Now()) &lt;= 60,
                    "46-60",
                    "60+"
                )
            )
        )
    )
),
VISIBLE = 1;

CREATE SET CURRENTCUBE.[Top 10 Customers] AS
TOPCOUNT(
    NONEMPTY(
        [Dim Customer].[Full Name].[Full Name].MEMBERS,
        [Measures].[Sales Amount]
    ),
    10,
    [Measures].[Sales Amount]
);

</Text>
        </Command>
      </Commands>
    </MdxScript>
  </MdxScripts>
</Cube>
